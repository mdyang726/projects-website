                display: flex;
                flex-direction: column;
                gap: 1rem;
            }

            footer {
                padding-top: 2rem;
                padding-bottom: 3rem;
                border-top: 1px solid #e0dfd8;
                display: flex;
                justify-content: space-between;
                align-items: center;
            }

            footer p {
