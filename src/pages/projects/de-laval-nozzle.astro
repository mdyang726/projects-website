                font-size: 14px;
                color: #888780;
                text-decoration: none;
            }

            .nav-links a:hover {
                color: #1a1a18;
            }

            .back-link {
                display: inline-block;
                font-family: "DM Mono", monospace;
                font-size: 12px;
                color: #888780;
                text-decoration: none;
                letter-spacing: 0.04em;
                margin-bottom: 2.5rem;
            }

            .back-link:hover {
                color: #1a1a18;
            }

            .hero {
                margin-bottom: 5rem;
            }

            .hero-label {
                font-family: "DM Mono", monospace;
                font-size: 12px;
                color: #b4b2a9;
                letter-spacing: 0.08em;
                text-transform: uppercase;
                margin-bottom: 1.25rem;
            }

            .hero h1 {
                font-family: "DM Serif Display", serif;
                font-size: 44px;
                font-weight: 400;
                line-height: 1.15;
                margin-bottom: 1.5rem;
            }

            .hero-desc {
                font-size: 16px;
                color: #5f5e5a;
                line-height: 1.7;
                max-width: 480px;
            }

            .section-label {
                font-family: "DM Mono", monospace;
                font-size: 11px;
